{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "#93A1A1",
          "style": "plain",
          "template": "╭─<#EEE8D5>{{ .UserName }}</>@<#586E75>{{ .HostName }}</> ",
          "type": "session"
        },
        {
          "background": "#073642",
          "foreground": "#268BD2",
          "properties": {
            "style": "full"
          },
          "style": "plain",
          "template": "  {{ .Path }} ",
          "type": "path"
        },
        {
          "foreground": "#586E75",
          "style": "plain",
          "template": "",
          "type": "text"
        },
        {
          "foreground": "#859900",
          "foreground_templates": [
            "{{ if or .Working.Changed .Staging.Changed }}#B58900{{ end }}",
            "{{ if gt .StashCount 0 }}#CB4B16{{ end }}"
          ],
          "properties": {
            "fetch_status": true
          },
          "style": "plain",
          "template": "  {{ .HEAD }}{{ if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} <#B58900> {{ .Working.String }}</>{{ end }}{{ if and (.Staging.Changed) (.Working.Changed) }} <#586E75>│</>{{ end }}{{ if .Staging.Changed }} <#2AA198> {{ .Staging.String }}</>{{ end }}{{ if gt .StashCount 0 }} <#CB4B16> {{ .StashCount }}</>{{ end }}{{ if gt .WorktreeCount 0 }} <#6C71C4> {{ .WorktreeCount }}</>{{ end }} ",
          "type": "git"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "segments": [
        {
          "foreground": "#93A1A1",
          "properties": {
            "time_format": "15:04:05"
          },
          "style": "plain",
          "template": "<#586E75>{{ .CurrentDate | date .Format }}</>",
          "type": "time"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#268BD2",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#DC322F{{ end }}"
          ],
          "properties": {
            "always_enabled": true
          },
          "style": "plain",
          "template": "╰─❯ ",
          "type": "status"
        }
      ],
      "type": "prompt"
    }
  ],
  "version": 4
}