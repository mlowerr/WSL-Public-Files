#!/bin/bash
# Run remove-nfo in parallel across multiple drives.

set -euo pipefail

INCLUDE_FLAG=""
if [[ "${1:-}" == "--include-0-downloads" ]]; then
  INCLUDE_FLAG="$1"
  shift
fi

drive_letters=(d e f g h i)

pids=()
for drive in "${drive_letters[@]}"; do
  mount_point="/mnt/$drive"
  args=()
  [[ -n "$INCLUDE_FLAG" ]] && args+=("$INCLUDE_FLAG")
  args+=("$mount_point")

  "$TOOLS_DIR/remove-nfo" "${args[@]}" &
  pids+=("$!")
  echo "Started remove-nfo for $mount_point with PID ${pids[-1]}"
done

for pid in "${pids[@]}"; do
  wait "$pid"
  echo "Process $pid completed"
done
